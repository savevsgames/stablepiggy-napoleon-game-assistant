# StablePiggy Napoleon Game Assistant — Relay Service Environment
#
# Copy this file to `.env` for local development. The real `.env` is
# gitignored and must never be committed.
#
# All variables are loaded at relay startup. Missing required variables cause
# the relay to refuse to start with a clear error message.

# -----------------------------------------------------------------------------
# Network
# -----------------------------------------------------------------------------

# TCP port the relay's WebSocket server binds to.
# Default: 8080 (matches the local dev convention).
RELAY_PORT=8080

# Optional bind address. Default: 0.0.0.0 (accept connections on all interfaces).
# Set to 127.0.0.1 if running on the same host as the Foundry client and you
# want to restrict access to localhost-only.
# RELAY_BIND_ADDRESS=0.0.0.0

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
#
# The relay supports two auth modes, selected per-connection by the prefix of
# the `authToken` field in the module's client.hello message:
#
#   1. API key (tokens starting with `dv-`) — resolved against the StablePiggy
#      backend via the identity endpoint. Unlocks vault access, campaign
#      memory, and per-user metering for the real identity behind the key.
#
#   2. Shared secret (anything else) — compared against RELAY_SHARED_SECRET
#      below. On match the relay synthesizes an anonymous identity
#      (`anon:<worldId>:<gmUserId>`) with no vault, no memory, no metering.
#
# Authentication previously used an HTTP Authorization header on the upgrade
# request, but browsers cannot set custom headers on WebSocket upgrades so
# auth moved into the first protocol message. The relay accepts all upgrades
# and runs a 2-second grace timer; connections that don't send a valid hello
# in time are closed with code 1008.

# Shared secret for anonymous auth. OPTIONAL — leave empty to disable
# shared-secret mode entirely (only dv- API keys will be accepted). Set this
# on self-hosted relays where you control who connects. For hosted relay
# deployments, leave empty and use RELAY_REQUIRE_API_KEY=true below.
#
# For local dev: any non-empty string works (e.g. "dev-test-secret").
# For production self-hosting: a 32-byte random value generated fresh.
# NEVER commit a real secret to git.
RELAY_SHARED_SECRET=dev-test-secret-do-not-ship

# When true, the relay rejects all shared-secret auth attempts and only
# accepts dv- API keys. Hosted deployments should set this to true so every
# connecting GM is tied to a real StablePiggy account. Default: false.
# RELAY_REQUIRE_API_KEY=false

# -----------------------------------------------------------------------------
# Backend (REQUIRED for Tier 1 Step 6+)
# -----------------------------------------------------------------------------

# URL of the StablePiggy AI backend's Foundry-query endpoint.
# This endpoint is delivered by the parallel Platform Track — see
# planning/phase2-tier1-plan.md §4.2 for the contract.
#
# For local dev (Platform Track P4 dev endpoint): something like
#   http://localhost:3000/api/foundry/query
# For production: the StablePiggy platform's production endpoint URL.
RELAY_BACKEND_URL=https://app.stablepiggy.com/dashboard/api/my/foundry/query     

# Bearer token the relay sends to the backend on every query request (the
# relay→backend service hop). Issued by the StablePiggy platform and stored
# in the vault under `napoleon-relay:backend_token`. This is SEPARATE from
# the user's StablePiggy API key — the backend token authenticates the relay
# itself, the user's API key authenticates the GM.
RELAY_BACKEND_TOKEN=dev-backend-token-do-not-ship

# URL of the backend's identity resolution endpoint. Called on hello when
# the auth token looks like a StablePiggy API key. OPTIONAL — if empty, the
# relay derives this from RELAY_BACKEND_URL by replacing the trailing
# `/query` segment with `/identity`, which matches the default deployment
# layout. Only set this explicitly if your backend routes the two endpoints
# differently.
# RELAY_BACKEND_IDENTITY_URL=

# -----------------------------------------------------------------------------
# Logging (optional)
# -----------------------------------------------------------------------------

# Log level: debug, info, warn, error
# Default: info
RELAY_LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Operational tuning (optional, sane defaults)
# -----------------------------------------------------------------------------

# Maximum messages queued per offline client connection before the oldest get
# dropped. Prevents unbounded memory growth if the AI backend pushes a lot of
# commands while the GM's browser is closed.
# Default: 100
RELAY_MAX_QUEUE_SIZE=100

# Maximum age (seconds) of a queued message before it is dropped on reconnect.
# Stale prep packages from yesterday should not arrive when the GM opens
# Foundry today.
# Default: 3600 (1 hour)
RELAY_MAX_QUEUE_AGE_SECONDS=3600

# Ping interval (seconds). The relay sends a ping to each connected client at
# this interval to detect dead connections.
# Default: 30
RELAY_PING_INTERVAL_SECONDS=30
