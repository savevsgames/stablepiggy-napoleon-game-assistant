{
  "name": "@stablepiggy-napoleon/protocol",
  "version": "0.0.1",
  "private": true,
  "description": "Shared protocol types for the StablePiggy Napoleon Game Assistant module and relay. The single source of truth for the WebSocket message contract.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    }
  },
  "files": [
    "dist",
    "index.ts",
    "types.ts"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "tsc && node dist/selftest.js"
  }
}
